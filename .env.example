# Required: Telegram Bot API credentials
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# Optional: Override the compose service name to watch (default: cap)
CAP_SERVICE_NAME=cap

# Optional: Docker label key to match (default: com.docker.compose.service)
# SERVICE_LABEL=com.docker.compose.service

# Optional: Custom regex for link extraction
# Inspect your logs first with: task logs:preview
# LINK_PATTERN=https?://[^\s"'\]}>]+(?:callback|verify|token|magic|signin|auth)[^\s"'\]}>]*

# Optional: Timing
# DISCOVERY_INTERVAL=5s
# RECONNECT_DELAY=3s

# Optional: Log verbosity (default: info)
# RUST_LOG=cap_link_notifier=debug
